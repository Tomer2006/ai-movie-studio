# Copy to .env and fill in. Used by studio CLI (python-dotenv).

# # Video generation (Replicate â€” https://replicate.com )
# Paste from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Model in owner/name format or full version URL (see Replicate model page)
# Example: minimax/video-01
REPLICATE_VIDEO_MODEL=minimax/video-01

# Optional JSON merged into Replicate "input" (model-specific knobs)
# REPLICATE_EXTRA_INPUT={"duration":6}

# xAI Grok Imagine â€” https://docs.x.ai/docs/guides/video-generation
XAI_API_KEY=
XAI_VIDEO_MODEL=grok-imagine-video
XAI_VIDEO_RESOLUTION=720p


# OpenRouter video — https://openrouter.ai/docs/guides/overview/multimodal/video-generation
OPENROUTER_API_KEY=
OPENROUTER_VIDEO_MODEL=alibaba/wan-2.6
OPENROUTER_VIDEO_RESOLUTION=480p
OPENROUTER_GENERATE_AUDIO=true
OPENROUTER_MAX_WAIT_SEC=900
OPENROUTER_POLL_INTERVAL=5

# Optional headers for OpenRouter attribution/ranking
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_X_TITLE=AI Movie Studio

# fal.ai (Model API queue) — https://fal.ai/models
# API key from https://fal.ai/dashboard/keys
FAL_KEY=
# Endpoint id from the model page, e.g. MiniMax Hailuo or Grok Imagine on fal:
# FAL_VIDEO_MODEL=fal-ai/minimax/hailuo-02/standard/text-to-video
# FAL_VIDEO_MODEL=xai/grok-imagine-video/text-to-video
FAL_VIDEO_MODEL=fal-ai/minimax/hailuo-02/standard/text-to-video
# For xai/grok-imagine-video/* only: 480p | 720p (default 720p when unset)
# FAL_VIDEO_RESOLUTION=720p
# FAL_MAX_WAIT_SEC=900
# FAL_POLL_INTERVAL=3
# Optional JSON merged into the request body (overrides auto duration when set)
# FAL_EXTRA_INPUT={"duration":"6","prompt_optimizer":true}

# Provider: replicate | xai | openrouter | fal | custom | mock (alias) | http | file:providers/my.json
# STUDIO_PROVIDER_CONFIG=providers/http.example.json
VIDEO_PROVIDER=custom



