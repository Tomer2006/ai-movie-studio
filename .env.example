# Copy to .env and fill in. Used by studio CLI (python-dotenv).

# Video generation (Replicate — https://replicate.com )
REPLICATE_API_TOKEN=

# Model in owner/name format or full version URL (see Replicate model page)
# Example: minimax/video-01
REPLICATE_VIDEO_MODEL=minimax/video-01

# Optional JSON merged into Replicate "input" (model-specific knobs)
# REPLICATE_EXTRA_INPUT={"duration":6}

# xAI Grok Imagine video — https://docs.x.ai/docs/guides/video-generation
XAI_API_KEY=
XAI_VIDEO_MODEL=grok-imagine-video
XAI_VIDEO_RESOLUTION=720p

# Provider: replicate | xai | mock | custom | file:providers/my.json
# For custom HTTP providers (see providers/README.md):
STUDIO_PROVIDER_CONFIG=providers/http.example.json

VIDEO_PROVIDER=mock
