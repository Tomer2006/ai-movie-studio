{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-movie-studio.local/schemas/scenes.schema.json",
  "title": "Scenes",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "scenes"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "shots"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "dialogue": { "type": "string" },
          "narration": { "type": "string" },
          "shots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "duration_sec", "prompt"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
                "duration_sec": { "type": "number", "exclusiveMinimum": 0, "maximum": 120 },
                "prompt": { "type": "string", "minLength": 1 },
                "negative_prompt": { "type": "string" },
                "reference_image_url": { "type": "string" },
                "seed": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
