{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-movie-studio.local/schemas/continuity_bible.schema.json",
  "title": "ContinuityBible",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "aspect_ratio",
    "fps",
    "characters",
    "locations",
    "visual_rules",
    "video_style"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "logline": { "type": "string" },
    "aspect_ratio": {
      "type": "string",
      "enum": ["16:9", "9:16", "1:1", "4:3", "21:9"]
    },
    "fps": { "type": "integer", "minimum": 12, "maximum": 60 },
    "tone": { "type": "string" },
    "era": { "type": "string" },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "wardrobe": { "type": "string" },
          "profile": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "physical_signature": { "type": "string" },
              "face": { "type": "string" },
              "hair": { "type": "string" },
              "eyes": { "type": "string" },
              "body": { "type": "string" },
              "movement": { "type": "string" },
              "personality": { "type": "string" },
              "voice": { "type": "string" },
              "consistency_notes": { "type": "string" },
              "negative_prompt": { "type": "string" },
              "reference_image_url": { "type": "string" },
              "seed": { "type": "integer" }
            }
          }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "visual_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "do": { "type": "array", "items": { "type": "string" } },
        "dont": { "type": "array", "items": { "type": "string" } },
        "color_palette": { "type": "array", "items": { "type": "string" } }
      }
    },
    "video_style": {
      "type": "object",
      "additionalProperties": false,
      "description": "Required. Project-wide look for the entire movie (every shot). Merged into every render prompt — not per-scene.",
      "required": ["aesthetic"],
      "properties": {
        "aesthetic": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*",
          "description": "Whole-film rendering style, e.g. photoreal live-action, anime / cel animation, documentary naturalism, stylized 3D. Same intent on every clip."
        },
        "look": { "type": "string" },
        "camera_language": { "type": "string" },
        "lighting": { "type": "string" },
        "texture_and_film": { "type": "string" },
        "color_grading": { "type": "string" },
        "motion_and_pacing": { "type": "string" },
        "consistency_notes": { "type": "string" },
        "negative_prompt": { "type": "string" }
      }
    },
    "reference_notes": { "type": "string" }
  }
}
