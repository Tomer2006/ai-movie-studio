{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-movie-studio.local/schemas/http_provider.schema.json",
  "title": "HttpVideoProviderConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "start", "job"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "description": { "type": "string" },
    "start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH"] },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": {}
      }
    },
    "job": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "video_url"],
          "properties": {
            "mode": { "type": "string", "const": "immediate" },
            "video_url": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path"],
              "properties": {
                "path": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "request_id", "poll", "status", "video_url"],
          "properties": {
            "mode": { "type": "string", "const": "poll" },
            "request_id": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path"],
              "properties": {
                "path": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            },
            "poll": {
              "type": "object",
              "additionalProperties": false,
              "required": ["url_template"],
              "properties": {
                "url_template": { "type": "string", "minLength": 1 },
                "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH"] },
                "headers": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "body": {},
                "interval_sec": { "type": "number", "exclusiveMinimum": 0 },
                "max_sec": { "type": "number", "minimum": 1 }
              }
            },
            "status": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "done_values"],
              "properties": {
                "path": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "pending_values": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "done_values": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "failed_values": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "video_url": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path"],
              "properties": {
                "path": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "download": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
