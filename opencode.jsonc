{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "director",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "read": { "*": "deny" },
        "glob": { "*": "deny" },
        "edit": "deny",
        "bash": "deny",
        "task": { "*": "deny" }
      }
    },
    "explore": {
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "read": { "*": "deny" },
        "glob": { "*": "deny" },
        "edit": "deny",
        "bash": "deny",
        "task": { "*": "deny" }
      }
    },
    "director": {
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "continuity_bible.example.json": "allow",
          "scenes.json": "allow",
          "schemas/*.json": "allow",
          "providers/*.json": "allow",
          ".opencode/skills/movie-studio/SKILL.md": "allow",
          ".opencode/agents/*.md": "allow",
          "clips/*.mp4": "allow",
          "dist/*.mp4": "allow",
          "dist/review/*.png": "allow",
          "dist/review/**/*.png": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "glob": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "continuity_bible.example.json": "allow",
          "scenes.json": "allow",
          "schemas/*.json": "allow",
          "providers/*.json": "allow",
          ".opencode/skills/movie-studio/SKILL.md": "allow",
          ".opencode/agents/*.md": "allow",
          "clips/*.mp4": "allow",
          "dist/*.mp4": "allow",
          "dist/review/*.png": "allow",
          "dist/review/**/*.png": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
        "todowrite": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "screenwriter": "allow",
          "shotboard": "allow",
          "quality-control": "allow"
        },
        "edit": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow"
        },
        "bash": {
          "*": "deny",
          "python -m studio *": "allow",
          "py -m studio *": "allow",
          "py -3 -m studio *": "allow"
        }
      }
    },
    "screenwriter": {
      "permission": {
        "read": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow"
        },
        "glob": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "shotboard": {
      "permission": {
        "read": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow"
        },
        "glob": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "quality-control": {
      "permission": {
        "read": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow",
          "clips/*.mp4": "allow",
          "dist/review/*.png": "allow",
          "dist/review/**/*.png": "allow"
        },
        "glob": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow",
          "clips/*.mp4": "allow",
          "dist/review/*.png": "allow",
          "dist/review/**/*.png": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
