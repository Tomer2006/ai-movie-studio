{
  "$schema": "https://opencode.ai/config.json",
  // Primary agent when starting a session (must be a primary agent, not a subagent).
  "default_agent": "director",
  // All OpenCode agent knobs: built-in toggles, director permissions, subagent permissions (optional hidden/temperature per agent).
  // Prompt text lives in `.opencode/agents/*.md`; keep this file for JSON-configurable behavior only.
  // Permissions use only "allow" or "deny" (never "ask"); see https://opencode.ai/docs/agents#permissions (last matching rule wins).
  // Project `opencode.json` also sets global permission defaults (merged with this file).
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow"
      }
    },
    "explore": {
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow"
      }
    },
    "director": {
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "screenwriter": "allow",
          "shotboard": "allow",
          "quality-control": "allow"
        },
        "edit": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow",
          "providers/*.json": "allow"
        },
        "bash": {
          "*": "deny",
          "python -m studio *": "allow",
          "py -m studio *": "allow",
          "py -3 -m studio *": "allow"
        }
      }
    },
    "screenwriter": {
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "shotboard": {
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "quality-control": {
      "permission": {
        "doom_loop": "deny",
        "question": "deny",
        "external_directory": "deny",
        "read": {
          "*": "allow",
          "*.env.example": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
