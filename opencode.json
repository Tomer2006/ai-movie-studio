{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": "deny"
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "mode": "subagent",
      "hidden": true
    },
    "explore": {
      "mode": "subagent",
      "hidden": true
    },
    "director": {
      "permission": {
        "task": {
          "*": "deny",
          "screenwriter": "allow",
          "shotboard": "allow",
          "quality-control": "allow"
        },
        "edit": {
          "*": "deny",
          "continuity_bible.json": "allow",
          "scenes.json": "allow",
          "providers/*.json": "allow"
        },
        "bash": {
          "*": "deny",
          "python -m studio *": "allow",
          "py -m studio *": "allow",
          "py -3 -m studio *": "allow"
        }
      }
    },
    "screenwriter": {
      "temperature": 0.65,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "shotboard": {
      "temperature": 0.55,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "quality-control": {
      "temperature": 0.3,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
