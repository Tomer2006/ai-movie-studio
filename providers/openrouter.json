{
  "version": 1,
  "description": "OpenRouter /videos API (model and resolution in body; poll until completed).",
  "start": {
    "url": "https://openrouter.ai/api/v1/videos",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${OPENROUTER_API_KEY}",
      "Content-Type": "application/json",
      "HTTP-Referer": "${OPENROUTER_HTTP_REFERER}",
      "X-Title": "AI Movie Studio"
    },
    "body": {
      "model": "alibaba/wan-2.6",
      "prompt": "{prompt}",
      "duration": "{duration_int}",
      "size": "832*480"
    }
  },
  "job": {
    "mode": "poll",
    "request_id": { "path": ["id"] },
    "poll": {
      "url_template": "https://openrouter.ai/api/v1/videos/{request_id}",
      "method": "GET",
      "headers": {
        "Authorization": "Bearer ${OPENROUTER_API_KEY}"
      },
      "interval_sec": 5,
      "max_sec": 1800
    },
    "status": {
      "path": ["status"],
      "done_values": ["completed"],
      "failed_values": ["failed", "cancelled", "expired"]
    },
    "video_url": {
      "path": ["url"]
    }
  }
}
